{
  "manifest_version": 3,
  "name": "GSC Weekend Filter",
  "description": "Removes weekends and holidays from Google Search Console performance charts",
  "version": "1.1.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://search.google.com/*",
    "https://date.nager.at/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://search.google.com/*"],
      "js": ["injected.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://search.google.com/*"],
      "js": ["content_script.js", "render_overlay.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GSC Weekend Filter",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
